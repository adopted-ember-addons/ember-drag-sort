{
  "extends": "@ember/app-tsconfig",
  "glint": {
    "environment": ["ember-loose", "ember-template-imports"]
  },
  "include": ["src/**/*", "tests/**/*", "demo-app/**/*"],
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "ember-drag-sort": ["./src"],
      "ember-drag-sort/*": ["./src/*"],
      "#src/*": ["./src/*"]
    },
    "types": ["ember-source/types", "vite/client", "@embroider/core/virtual"]
  }
}
